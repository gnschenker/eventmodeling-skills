{
  "name": "todo-list-backend",
  "version": "1.0.0",
  "description": "Todo List App — backend (Node.js + Express + aggregateless ES with DCB)",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test **/*.test.js",
    "test:unit": "node --test --test-name-pattern=unit **/*.test.js",
    "test:integration": "node --test --test-name-pattern=integration **/*.test.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "es-dcb-library": "^1.0.0",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
